DISCORD_TOKEN=
CLIENT_ID=

# Use "guild" for fast command updates while developing.
# Use "global" when commands should appear in every server where the bot is installed.
COMMAND_DEPLOY_SCOPE=guild

# Comma-separated guild IDs. GUILD_ID is still supported for one server.
GUILD_IDS=
GUILD_ID=

# Optional: Netscape cookies.txt file used by yt-dlp when YouTube blocks a server IP.
# Keep this file private and never commit it.
YT_DLP_COOKIES_FILE=
