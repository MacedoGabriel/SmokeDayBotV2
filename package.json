{
  "name": "smoke-day-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon --legacy-watch --watch src --ext ts --exec \"tsx src/index.ts\"",
    "start": "node dist/index.js",
    "build": "tsc",
    "check": "tsc --noEmit",
    "doctor": "node scripts/doctor.mjs",
    "deploy:commands": "tsx src/deploy-commands.ts",
    "deploy:commands:prod": "node dist/deploy-commands.js"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.0",
    "discord.js": "^14.21.0",
    "dotenv": "^17.2.3",
    "libsodium-wrappers": "^0.7.15"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "nodemon": "^3.1.14",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
